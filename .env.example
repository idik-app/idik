# Salin ke .env.local: cp .env.example .env.local  |  Windows: copy .env.example .env.local
# Isi nilai di bawah. Jangan commit .env.local.
# Auth & env: docs/AUTH-DB.md  |  Cek: npm run check:auth-env

# Wajib untuk production (next start / deploy). Disarankan sama di .env.local agar cookie JWT konsisten dengan middleware.
JWT_SECRET=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Opsional: URL publik (bukan untuk LoginModal — login memakai same-origin /api/auth).
# Hanya jika fitur lain butuh origin eksplisit.
# NEXT_PUBLIC_APP_URL=https://your-domain.com
