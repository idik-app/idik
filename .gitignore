# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# Google Apps Script / clasp
.clasp.json

# misc
.DS_Store
*.pem
Thumbs.db
desktop.ini

# ekspor CSV sheet besar (impor lokal)
scripts/sheet-export*.csv

# database dumps (backup schema/data, bisa berisi data sensitif)
dump.sql
*.dump.sql

# archives (jangan push asset besar / backup)
*.zip
*.tar
*.tar.gz
*.rar

# backup / salinan file (e.g. "page copy.tsx")
* copy.*
* copy *

# editor / temp
.idea/
*.swp
*.swo
*.bak
*.tmp

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
