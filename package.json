    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.37.0",
    "eslint-config-next": "15.5.4",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "postcss": "^8.5.6",
    "rimraf": "^6.0.1",
    "supabase": "^2.54.11",
    "tailwindcss": "^3.4.18",
    "turbo": "^2.8.16",
    "typescript": "^5"
  }
}
