{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,

    "plugins": [{ "name": "next" }],

    /* ============================================================
       🔥 OFFICIAL JARVIS MODE ALIAS (NO CONFLICT)
       ============================================================ */
    "paths": {
      "@/core/*": ["core/*"],
      "@/modules/*": ["app/modules/*"],
      "@/contexts/*": ["app/contexts/*"],
      "@/dashboard/*": ["app/dashboard/*"],
      "@/components/*": ["components/*"],
      "@/hooks/*": ["app/hooks/*"],
      "@/utils/*": ["app/utils/*"],
      "@/lib/*": ["lib/*"],
      "@/pasien/*": ["app/dashboard/pasien/*"],
      "@/inventaris/*": ["app/dashboard/inventaris/*"],
      "@/database/*": ["app/dashboard/database/*"],
      "@/trading/*": ["app/dashboard/trading/*"],
      "@/styles/*": ["app/styles/*"],
      "@/*": ["*"]
    },

    /* Agar TypeScript mengenali deklarasi khusus */
    "typeRoots": ["./types", "./node_modules/@types"]
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "app",
    "types",
    ".next/dev/types/**/*.ts",
    "next.config.js"
  ],

  "exclude": [
    "node_modules",
    "scripts/dbSync.ts",
    "**/*.backup.ts",
    "**/*.backup.tsx",
    "app/dashboard/pasien/contexts/core/**",
    "app/dashboard/pasien/contexts/usePasienCrud.ts",
    "app/dashboard/pasien/contexts/usePasienFilter.ts",
    "app/dashboard/pasien/hooks/usePasienInsight.ts",
    "app/dashboard/pasien/hooks/usePasienSync.ts",
    "app/dashboard/pasien/insights/pasienInsight.ts",
    "app/dashboard/pasien/utils/validator.ts",
    "app/dashboard/pasien/index.tsx",
    "app/dashboard/pasien/PasienDashboardContent.tsx",
    "app/interface",
    "app/interface/**",
    "app/modules",
    "app/modules/**",
    "app\\modules",
    "app\\modules\\**"
    ,
    "app/system",
    "app/system/**",
    "core",
    "core/**",
    "components/dashboard/**",
    "components/global/ExportShare/**",
    "app/services/WatcherService.ts"
    ,
    "app/system/api-keys/**",
    "app/system/database/**",
    "components/global/ExportShare",
    "components/global/ExportShare/**",
    "core/registry/ModuleRegistry.ts"
  ]
}
